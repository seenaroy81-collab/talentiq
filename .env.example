# -----------------------------------------------------------------------------
# BACKEND ENVIRONMENT VARIABLES (Add these to Render.com)
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=production
CLIENT_URL=https://your-app.vercel.app

# Database (MongoDB Atlas)
DB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/talent-iq

# Redis (Upstash) - Must start with rediss:// for TLS
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6380

# Email (Resend API)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Auth (Clerk - Use LIVE keys for production)
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx

# AI (Groq)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# Video/Chat (Stream.io)
STREAM_API_KEY=xxxxxxxxxxxx
STREAM_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Background Tasks (Inngest)
INNGEST_EVENT_KEY=xxxxxxxxxxxxxxxx
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxxxxxxxxxx

# Candidate Auth
JWT_SECRET=your-random-secret-at-least-32-chars

# Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=xxxxxxxx
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# FRONTEND ENVIRONMENT VARIABLES (Add these to Vercel.com)
# -----------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
VITE_API_URL=https://your-backend.onrender.com/api
VITE_STREAM_API_KEY=xxxxxxxxxxxx
